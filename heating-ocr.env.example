# heating-ocr.env — loaded by systemd EnvironmentFile=
# Copy this file to heating-ocr.env and fill in the values.

# Required — the service will refuse to start without these
MQTT_USER=mqtt
MQTT_PASS=changeme
MQTT_HOST=your-mqtt-host
MQTT_PORT=1883
VNC_HOST=your-vnc-host
VNC_PASS=changeme
# Optional — only needed if vncdo binary is at a non-standard path
#VNCDO_CMD=/usr/local/bin/vncdo
